SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your-secret-service-role-key
ANTHROPIC_API_KEY=your-anthropic-api-key
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
# Fallback chat used only when a unit's own telegram_chat_id column is empty
TELEGRAM_CHAT_ID=your-default-telegram-chat-id
# Gmail address + App Password (myaccount.google.com/apppasswords) — used
# by the nightly email receipt scraper, read via IMAP.
EMAIL_USER=your-gmail-address@gmail.com
EMAIL_PASSWORD=your-16-character-app-password
# Public URL Jeeves links back to in Telegram messages (e.g. a Cloudflare
# Tunnel / ngrok URL once deployed from the Mac Mini). Leave unset for
# local-only use — falls back to http://localhost:8501.
BASE_URL=http://localhost:8501
# Required for the app to load at all once ACCESS_TOKEN is set — every
# request must include ?token=<this value> or it gets the Access Denied
# page. Generate with: python -c "import secrets; print(secrets.token_urlsafe(24))"
ACCESS_TOKEN=your-long-random-access-token
